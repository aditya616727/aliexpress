# Environment – development or production (controls which MongoDB URI is used)
NODE_ENV=development

# MongoDB – full URI with user, password, host, database
# NODE_ENV=development → MONGODB_URI_DEV, NODE_ENV=production → MONGODB_URI_PROD
# Fallback: MONGODB_URI when NODE_ENV not set
MONGODB_URI=mongodb+srv://user:password@host.net/scraper_db?appName=your-app
MONGODB_URI_DEV=mongodb+srv://user:password@dev-host.net/scraper_db?appName=your-app
MONGODB_URI_PROD=mongodb+srv://user:password@prod-host.net/scraper_db?appName=your-app

# Logging
LOG_LEVEL=INFO

# Translation – DeepL API (recommended; no rate limits)
# Get key at https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Proxy (optional) – Webshare API
USE_PROXY=false
WEBSHARE_API_KEY=your_api_key_here

# Parallelism (optional – defaults shown)
NUM_SCRAPER_WORKERS=4
NUM_CONSUMER_WORKERS=3
CONSUMER_BATCH_SIZE=4

# Cloudflare - for storing images
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
